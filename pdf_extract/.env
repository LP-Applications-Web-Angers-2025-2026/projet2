# Configuration des scripts d'extraction PDF
# Copiez ce fichier en .env et adaptez les chemins selon votre environnement

# Chemin vers le fichier PDF source
PDF_PATH=../Programmation_Assembleur_x86_32_et_64_bits_sous_Linux_Ubuntu.pdf

# Chemin vers la base de données SQLite
DB_PATH=../site_web/data/benchmarks.db

# Répertoire de sortie pour les fichiers markdown générés
OUTPUT_DIR=../site_web/pages-md

# Répertoire de sortie pour les fichiers JSON
DATA_DIR=../site_web/data
